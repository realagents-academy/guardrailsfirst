---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Guardrails First — AI that ships in regulated enterprises',
  description = 'Practitioner notes on shipping AI in regulated enterprises. Real scenarios, real blockers, real patterns. By Alex Araujo.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': 'https://www.guardrailsfirst.com/#person',
      name: 'Alex Araujo',
      url: 'https://www.araujoinnovations.ch',
      jobTitle: 'Microsoft AI Architect',
      description:
        'Microsoft AI Architect, MCT, Azure AI Architect, AI CERTs Advisory Board member. Writes Guardrails First — practitioner notes on shipping AI in regulated enterprises.',
      worksFor: {
        '@type': 'Organization',
        name: 'Real Agents Academy',
        url: 'https://realagents.academy',
      },
      sameAs: [
        'https://www.araujoinnovations.ch',
        'https://guardrailsfirst.substack.com',
        'https://www.youtube.com/@guardrailsfirst',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://www.guardrailsfirst.com/#website',
      url: 'https://www.guardrailsfirst.com/',
      name: 'Guardrails First',
      description:
        'Practitioner notes on shipping AI in regulated enterprises. Real scenarios, real blockers, real patterns. By Alex Araujo.',
      inLanguage: 'en',
      publisher: {
        '@type': 'Organization',
        name: 'Real Agents Academy',
        url: 'https://realagents.academy',
      },
      author: { '@id': 'https://www.guardrailsfirst.com/#person' },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#0B1F3A" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Guardrails First" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Guardrails First — AI that ships in regulated enterprises" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <meta name="author" content="Alex Araujo" />
    <meta name="robots" content="index, follow" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>
