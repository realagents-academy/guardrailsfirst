---
interface SocialLink {
  name: string;
  url: string;
  ariaLabel: string;
}

const links: SocialLink[] = [
  {
    name: 'substack',
    url: 'https://guardrailsfirst.substack.com',
    ariaLabel: 'Subscribe on Substack',
  },
  {
    name: 'youtube',
    url: 'https://www.youtube.com/@guardrailsfirst',
    ariaLabel: 'Watch on YouTube',
  },
  {
    name: 'email',
    url: 'mailto:hello@guardrailsfirst.com',
    ariaLabel: 'Email hello@guardrailsfirst.com',
  },
];
---

<ul class="social">
  {
    links.map(({ name, url, ariaLabel }) => (
      <li class="social__item">
        <a class="social__link" href={url} aria-label={ariaLabel} rel="noopener">
          {name === 'substack' && (
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z" />
            </svg>
          )}
          {name === 'youtube' && (
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
            </svg>
          )}
          {name === 'email' && (
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="2" y="4" width="20" height="16" rx="2" />
              <path d="m2 7 10 6 10-6" />
            </svg>
          )}
        </a>
      </li>
    ))
  }
</ul>

<style>
  .social {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-3);
  }

  .social__item {
    display: flex;
  }

  .social__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-text-muted);
    border-radius: var(--radius-md);
    transition: color var(--transition), background-color var(--transition);
  }

  .social__link:hover {
    color: var(--color-accent);
    background-color: var(--color-surface);
  }

  .social__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
